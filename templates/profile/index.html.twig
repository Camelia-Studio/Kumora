{% extends 'base.html.twig' %}

{% block title %}Le disque nuagique de Camélia Studio{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 md:px-8 lg:px-16 mb-4">
        <div class="mt-4">
            <h1 class="text-2xl md:text-3xl font-bold mb-6 text-gray-900 dark:text-white">Mon Profil</h1>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="lg:col-span-1">
                    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                    <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4">
                            <div class="relative flex-shrink-0 group">
                                <img src="{{ user.avatarFilename ? asset('uploads/avatars/' ~ user.avatarFilename) : get_gravatar(user.email) }}"
                                     alt="Avatar de {{ user.fullname }}"
                                     class="w-20 h-20 md:w-24 md:h-24 rounded-lg object-cover">
                                <a href="{{ path('app_profile_avatar_edit') }}"
                                   class="absolute inset-0 flex items-center justify-center rounded-lg bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity"
                                   title="Modifier l'avatar">
                                    <twig:ux:icon name="line-md:pencil" class="w-6 h-6 text-white" />
                                </a>
                            </div>
                            <div class="text-center sm:text-left">
                                <h2 class="text-xl md:text-2xl font-semibold text-gray-900 dark:text-white">{{ user.fullname }}</h2>
                                <p class="text-gray-600 dark:text-gray-400 mt-1">{{ user.roles[0] == 'ROLE_ADMIN' ? 'Administrateur' : 'Utilisateur' }}</p>
                                {% if user.avatarFilename %}
                                    <form method="post" action="{{ path('app_profile_avatar_delete') }}" class="mt-2"
                                          onsubmit="return confirm('Supprimer votre image de profil ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_avatar') }}">
                                        <button type="submit"
                                                class="inline-flex items-center gap-1 text-xs text-red-500 hover:text-red-600 dark:text-red-400 dark:hover:text-red-300 transition-colors">
                                            <twig:ux:icon name="fa6-solid:trash" class="w-3 h-3" />
                                            Supprimer l'avatar
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="p-4 md:p-6 space-y-4">
                        {# Email #}
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                            <div class="flex-1 min-w-0">
                                <span class="font-medium text-gray-900 dark:text-white">Email :</span>
                                <span class="text-gray-600 dark:text-gray-300 ml-2 break-all">{{ user.email }}</span>
                            </div>
                            <a href="{{ path('app_profile_email_edit') }}"
                               class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-md transition-colors flex-shrink-0">
                                <twig:ux:icon name="line-md:pencil" class="w-4 h-4" />
                                <span class="hidden sm:inline">Modifier</span>
                            </a>
                        </div>

                        {# Groupe d'accès #}
                        <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                            <span class="font-medium text-gray-900 dark:text-white">Groupe d'accès :</span>
                            <span class="text-gray-600 dark:text-gray-300 ml-2">{{ user.accessGroup.name }}</span>
                        </div>

                        {# Actions #}
                        <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
                            <a href="{{ path('app_profile_password_edit') }}"
                               class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:focus:ring-blue-800 rounded-lg transition-colors">
                                <twig:ux:icon name="fa6-solid:key" class="w-4 h-4" />
                                Modifier mon mot de passe
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                    <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                            <div>
                                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Historique des actions</h2>
                                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{{ total_actions }} actions effectuées au total</p>
                            </div>

                            {# Statistiques rapides #}
                            <div class="flex flex-wrap gap-2">
                                {% for actionType, count in action_stats|slice(0, 3) %}
                                    <div class="inline-flex items-center gap-1 px-2 py-1 bg-gray-100 dark:bg-gray-700 rounded-md text-xs text-gray-600 dark:text-gray-300">
                                        <twig:ux:icon name="{{ actionType|action_icon }}" class="w-3 h-3 {{ actionType|action_color }}" />
                                        <span>{{ count }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="p-4 md:p-6">
                        {% if recent_actions is empty %}
                            <div class="text-center py-8">
                                <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                                    <twig:ux:icon name="fa6-solid:clock" class="w-8 h-8 text-gray-400" />
                                </div>
                                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Aucune action récente</h3>
                                <p class="text-gray-600 dark:text-gray-400">Votre historique d'actions apparaîtra ici dès que vous commencerez à utiliser l'outil.</p>
                            </div>
                        {% else %}
                            <div class="space-y-4">
                                {% for action in recent_actions %}
                                    <div class="flex items-start gap-4 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-white dark:bg-gray-800 shadow-sm flex-shrink-0">
                                            <twig:ux:icon name="{{ action.actionIcon }}" class="w-5 h-5 {{ action.actionColor }}" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-gray-900 dark:text-white">
                                                {{ action.description }}
                                            </p>
                                            {% if action.targetPath and action.metadata['is_public'] is defined and action.metadata['is_public'] %}
                                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 font-mono bg-gray-200 dark:bg-gray-600 px-2 py-1 rounded inline-block">
                                                    {{ action.targetPath }}
                                                </p>
                                            {% endif %}
                                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">
                                                <twig:ux:icon name="fa6-solid:clock" class="w-3 h-3 inline mr-1" />
                                                {{ action.createdAt|time_diff }}
                                            </p>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            </div>
        </div>
    </div>

{% endblock %}
