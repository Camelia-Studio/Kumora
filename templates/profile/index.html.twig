{% extends 'base.html.twig' %}

{% block title %}Le disque nuagique de Camélia Studio{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 md:px-8 lg:px-16">
        <div class="mt-4">
            <h1 class="text-2xl md:text-3xl font-bold mb-6 text-gray-900 dark:text-white">Mon Profil</h1>
            
            <div class="max-w-2xl">
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                    {# Avatar et nom #}
                    <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4">
                            <img src="{{ get_gravatar(user.email) }}" alt="Avatar de {{ user.fullname }}" class="w-20 h-20 md:w-24 md:h-24 rounded-lg flex-shrink-0">
                            <div class="text-center sm:text-left">
                                <h2 class="text-xl md:text-2xl font-semibold text-gray-900 dark:text-white">{{ user.fullname }}</h2>
                                <p class="text-gray-600 dark:text-gray-400 mt-1">{{ user.roles[0] == 'ROLE_ADMIN' ? 'Administrateur' : 'Utilisateur' }}</p>
                            </div>
                        </div>
                    </div>

                    {# Informations #}
                    <div class="p-4 md:p-6 space-y-4">
                        {# Email #}
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                            <div class="flex-1 min-w-0">
                                <span class="font-medium text-gray-900 dark:text-white">Email :</span>
                                <span class="text-gray-600 dark:text-gray-300 ml-2 break-all">{{ user.email }}</span>
                            </div>
                            <a href="{{ path('app_profile_email_edit') }}" 
                               class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 rounded-md transition-colors flex-shrink-0">
                                <twig:ux:icon name="line-md:pencil" class="w-4 h-4" />
                                <span class="hidden sm:inline">Modifier</span>
                            </a>
                        </div>

                        {# Groupe d'accès #}
                        <div class="p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                            <span class="font-medium text-gray-900 dark:text-white">Groupe d'accès :</span>
                            <span class="text-gray-600 dark:text-gray-300 ml-2">{{ user.accessGroup.name }}</span>
                        </div>

                        {# Actions #}
                        <div class="pt-4 border-t border-gray-200 dark:border-gray-700">
                            <a href="{{ path('app_profile_password_edit') }}" 
                               class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 dark:focus:ring-blue-800 rounded-lg transition-colors">
                                <twig:ux:icon name="fa6-solid:key" class="w-4 h-4" />
                                Modifier mon mot de passe
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}