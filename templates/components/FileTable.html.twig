<div{{ attributes }}>
    {% if this.parentDir == null or (this.parentDir != null and is_granted('file_write', this.parentDir)) %}
        <div class="flex flex-col lg:flex-row lg:justify-end gap-2">
            <a href="{{ path('app_files_create_directory', {
                base: path
            }) }}" class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 rounded-lg dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800 transition-colors w-full lg:w-auto">
                <twig:ux:icon name="fa6-solid:folder-plus" class="w-4 h-4 mr-2" />
                Créer un dossier
            </a>
            {% if path != '' %}
                <a href="{{ path('app_files_upload', {
                    path: path
                }) }}" class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 rounded-lg dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800 transition-colors w-full lg:w-auto">
                    <twig:ux:icon name="fa6-solid:upload" class="w-4 h-4 mr-2" />
                    Ajouter des fichiers
                </a>
            {% endif %}
        </div>
    {% endif %}
    <div class="mt-4">
        {% if path != '' %}
            <div class="mb-4">
                {% set parentPath = path|split('/')|slice(0, -1)|join('/') %}
                <button
                    type="button"
                    data-model="path"
                    data-value="{{ parentPath }}"
                    data-action="live#update"
                    class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-gray-600 hover:bg-gray-700 focus:ring-4 focus:ring-gray-300 rounded-lg dark:bg-gray-500 dark:hover:bg-gray-600 focus:outline-none dark:focus:ring-gray-700 transition-colors w-full lg:w-auto">
                    <twig:ux:icon name="fa6-solid:arrow-left" class="w-4 h-4 mr-2" />
                    Retour
                </button>
            </div>
        {% endif %}
        {% include 'partials/breadbrumb.html.twig' %}
    </div>



    {# Desktop Table View #}
    <div class="hidden lg:block relative overflow-x-auto mt-4">
        <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
            <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
                <th scope="col" class="px-6 py-3">
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="toggleSort"
                        data-live-column-param="name"
                        class="flex items-center gap-1 hover:text-gray-900 dark:hover:text-gray-200 transition-colors group">
                        <span>Nom</span>
                        {% if sortBy == 'name' %}
                            <twig:ux:icon name="fa6-solid:chevron-{{ sortDirection == 'asc' ? 'up' : 'down' }}" class="w-3 h-3" />
                        {% else %}
                            <twig:ux:icon name="fa6-solid:sort" class="w-3 h-3 opacity-50 group-hover:opacity-100" />
                        {% endif %}
                    </button>
                </th>
                <th scope="col" class="px-6 py-3">
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="toggleSort"
                        data-live-column-param="size"
                        class="flex items-center gap-1 hover:text-gray-900 dark:hover:text-gray-200 transition-colors group">
                        <span>Taille</span>
                        {% if sortBy == 'size' %}
                            <twig:ux:icon name="fa6-solid:chevron-{{ sortDirection == 'asc' ? 'up' : 'down' }}" class="w-3 h-3" />
                        {% else %}
                            <twig:ux:icon name="fa6-solid:sort" class="w-3 h-3 opacity-50 group-hover:opacity-100" />
                        {% endif %}
                    </button>
                </th>
                <th scope="col" class="px-6 py-3">
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="toggleSort"
                        data-live-column-param="date"
                        class="flex items-center gap-1 hover:text-gray-900 dark:hover:text-gray-200 transition-colors group">
                        <span>Dernière modification</span>
                        {% if sortBy == 'date' %}
                            <twig:ux:icon name="fa6-solid:chevron-{{ sortDirection == 'asc' ? 'up' : 'down' }}" class="w-3 h-3" />
                        {% else %}
                            <twig:ux:icon name="fa6-solid:sort" class="w-3 h-3 opacity-50 group-hover:opacity-100" />
                        {% endif %}
                    </button>
                </th>
                <th scope="col" class="px-6 py-3">
                    <button
                        type="button"
                        data-action="live#action"
                        data-live-action-param="toggleSort"
                        data-live-column-param="type"
                        class="flex items-center gap-1 hover:text-gray-900 dark:hover:text-gray-200 transition-colors group">
                        <span>Type</span>
                        {% if sortBy == 'type' %}
                            <twig:ux:icon name="fa6-solid:chevron-{{ sortDirection == 'asc' ? 'up' : 'down' }}" class="w-3 h-3" />
                        {% else %}
                            <twig:ux:icon name="fa6-solid:sort" class="w-3 h-3 opacity-50 group-hover:opacity-100" />
                        {% endif %}
                    </button>
                </th>
                <th scope="col" class="px-6 py-3">
                    Groupes d'accès
                </th>
                <th scope="col" class="px-6 py-3">
                    Actions
                </th>
            </tr>
            </thead>
            <tbody>
            {% for file in this.files %}
                {% if this.parentDir == null %}
                    {% set parentDirectory = get_parent_dir(file.path) %}
                {% else %}
                    {% set parentDirectory = this.parentDir %}
                {% endif %}
                <tr class="{{ parentDirectory.public ? 'bg-white dark:bg-gray-800' : 'bg-gray-50 dark:bg-gray-900' }} border-b dark:border-gray-700 group">
                    {% if file.type == 'file' %}
                        <td class="px-6 py-4 font-medium light:text-gray-900 whitespace-nowrap cursor-pointer">
                            <button onclick="openPreviewModal('{{ file.path|basename }}', '{{ file.previewUrl }}', '{{ file.url }}')" class="flex gap-2 items-center w-full h-full duration-300 group-[:hover:not(:has(.links-total:hover))]:text-blue-900  dark:group-[:hover:not(:has(.links-total:hover))]:text-blue-700 text-left">
                                {% if not parentDirectory.public %}
                                    <twig:ux:icon name="fa6-solid:lock" class="w-4 h-4 text-amber-600 dark:text-amber-500 flex-shrink-0" />
                                {% endif %}
                                <twig:ux:icon name="{{ getIcons(file.path|basename) }}" class="w-6 h-6" />
                                {{ file.path|basename }}
                            </button>
                        </td>
                        <td class="px-6 py-4">
                            <a href="{{ file.previewUrl }}" target="_blank" class="w-full h-full block">{{ file.size|show_size }}</a>
                        </td>
                        <td class="px-6 py-4">
                            <a href="{{ file.previewUrl }}" target="_blank" class="w-full h-full block">{{ file.last_modified|time_diff }}</a>
                        </td>
                        <td class="px-6 py-4">
                            <a href="{{ file.previewUrl }}" target="_blank" class="w-full h-full block">
                                {% set fileType = getFileType(file.path|basename) %}
                                <span class="text-sm text-gray-600 dark:text-gray-400">{{ fileType.label }}</span>
                            </a>
                        </td>
                        <td class="px-6 py-4">
                            <a href="{{ file.previewUrl }}" target="_blank" class="w-full h-full block">
                                {% if this.parentDir == null %}
                                    {% set parentDirectory = get_parent_dir(file.path) %}
                                {% else %}
                                    {% set parentDirectory = this.parentDir %}
                                {% endif %}
                                {% if parentDirectory.public %}
                                    <div class="flex gap-1">
                                        {% for parentRole in getHigherRoles(parentDirectory.ownerRole) %}
                                            <img class="w-6 h-6" title="{{ parentRole.name }}" src="{{ parentRole.image ?? ('https://ui-avatars.com/api/?name=' ~ parentRole.name) }}" alt="">
                                        {% endfor %}
                                        {% if parentDirectory.ownerRole is not null %}
                                            <img class="w-6 h-6" title="{{ parentDirectory.ownerRole.name }}" src="{{ parentDirectory.ownerRole.image ?? ('https://ui-avatars.com/api/?name=' ~ parentDirectory.ownerRole.name) }}" alt="">
                                        {% endif %}
                                        {% for permission in parentDirectory.parentDirectoryPermissions %}
                                            <img class="w-6 h-6" title="{{ permission.role.name }}" src="{{ parentDirectory.ownerRole.image ?? ('https://ui-avatars.com/api/?name=' ~ permission.role.name) }}" alt="">
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <div class="flex items-center gap-1">
                                        <p class="text-gray-600 dark:text-gray-300">Dossier privé</p>
                                    </div>
                                {% endif %}
                            </a>
                        </td>
                    {% else %}
                        <td class="px-6 py-4 font-medium light:text-gray-900 whitespace-nowrap cursor-pointer">
                            <button
                                    type="button"
                                    data-model="path"
                                    data-value="{{ file.path }}"
                                    data-action="live#update"
                                    class="flex gap-2 items-center w-full h-full duration-300 group-[:hover:not(:has(.links-total:hover))]:text-blue-900  dark:group-[:hover:not(:has(.links-total:hover))]:text-blue-700 cursor-pointer">
                                {% if not parentDirectory.public %}
                                    <twig:ux:icon name="fa6-solid:lock" class="w-4 h-4 text-amber-600 dark:text-amber-500 flex-shrink-0" />
                                {% endif %}
                                <twig:ux:icon name="line-md:folder-filled" class="w-6 h-6" />
                                {{ file.path|basename }}
                            </button>
                        </td>
                        <td class="px-6 py-4">
                            <button type="button"
                                    data-model="path"
                                    data-value="{{ file.path }}"
                                    data-action="live#update" class="text-left h-full w-full cursor-pointer">{{ file.size|show_size }}</button>
                        </td>
                        <td class="px-6 py-4">
                            <button type="button"
                               data-model="path"
                               data-value="{{ file.path }}"
                               data-action="live#update" class="text-left h-full w-full cursor-pointer">{{ file.last_modified|time_diff }}</button>
                        </td>
                        <td class="px-6 py-4">
                            <button type="button"
                               data-model="path"
                               data-value="{{ file.path }}"
                               data-action="live#update" class="text-left h-full w-full cursor-pointer">
                                <span class="text-sm text-gray-600 dark:text-gray-400">Dossier</span>
                            </button>
                        </td>
                        <td class="px-6 py-4">
                            <button type="button"
                               data-model="path"
                               data-value="{{ file.path }}"
                               data-action="live#update" class="text-left h-full w-full cursor-pointer">
                                {% if this.parentDir == null %}
                                    {% set parentDirectory = get_parent_dir(file.path) %}
                                {% else %}
                                    {% set parentDirectory = this.parentDir %}
                                {% endif %}
                                {% if parentDirectory.public %}
                                    <div class="flex gap-1">
                                        {% for parentRole in getHigherRoles(parentDirectory.ownerRole) %}
                                            <img class="w-6 h-6" title="{{ parentRole.name }}" src="{{ parentRole.image ?? ('https://ui-avatars.com/api/?name=' ~ parentRole.name) }}" alt="">
                                        {% endfor %}
                                        {% if parentDirectory.ownerRole is not null %}
                                            <img class="w-6 h-6" title="{{ parentDirectory.ownerRole.name }}" src="{{ parentDirectory.ownerRole.image ?? ('https://ui-avatars.com/api/?name=' ~ parentDirectory.ownerRole.name) }}" alt="">
                                        {% endif %}
                                        {% for permission in parentDirectory.parentDirectoryPermissions %}
                                            <img class="w-6 h-6" title="{{ permission.role.name }}" src="{{ parentDirectory.ownerRole.image ?? ('https://ui-avatars.com/api/?name=' ~ permission.role.name) }}" alt="">
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <div class="flex items-center gap-1">
                                        <p class="text-gray-600 dark:text-gray-300">Dossier privé</p>
                                    </div>
                                {% endif %}
                            </button>
                        </td>
                    {% endif %}
                    <td class="px-6 py-4 flex gap-2 light:text-black links-total">
                        {% if file.type == 'file' %}
                            <button title="Permet de voir le fichier" onclick="openPreviewModal('{{ file.path|basename }}', '{{ file.previewUrl }}', '{{ file.url }}')" class="hover:text-blue-700 duration-300"><twig:ux:icon class="w-6 h-6" name="fa6-solid:eye" /></button>
                            <button title="Permet de copier le lien de prévisualisation du fichier" onclick="navigator.clipboard.writeText('{{ file.previewUrl }}'); customAlert('Lien copié avec succès !', 'Copie réussie')"  class="hover:text-blue-700 duration-300"><twig:ux:icon class="w-6 h-6 cursor-pointer" name="fa6-solid:clipboard" /></button>
                            <a title="Permet de télécharger le fichier" href="{{ file.url }}" class="hover:text-blue-700 duration-300"><twig:ux:icon class="w-6 h-6" name="fa6-solid:download" /></a>
                            {% if is_granted('file_write', parentDirectory) %}
                                <a title="Permet de renommer le fichier" href="{{ path('app_files_rename', {
                                    path: file.path
                                }) }}" class="hover:text-blue-700 duration-300"><twig:ux:icon class="w-6 h-6" name="fa6-solid:pencil" /></a>
                                <a title="Permet de déplacer le fichier" href="{{ path('app_files_move', {
                                    path: file.path
                                }) }}" class="hover:text-blue-700 duration-300"><twig:ux:icon class="w-6 h-6" name="mdi:file-move" /></a>
                                <a title="Permet de supprimer le fichier" onclick="event.preventDefault(); const url = this.href; customConfirm('Veux-tu vraiment supprimer ce fichier ?', 'Supprimer le fichier').then(confirmed => {
                                    if (confirmed) {
                                        window.location.href = url
                                    }
                                })" href="{{
                                path('app_files_delete', {
                                    filename: file.path
                                })
                                }}" class="hover:text-red-700 duration-300"><twig:ux:icon class="w-6 h-6" name="fa6-solid:trash-can" /></a>
                            {% endif %}
                        {% else %}
                            {% if this.parentDir == null %}
                                {% set parentDirectory = get_parent_dir(file.path) %}
                            {% else %}
                                {% set parentDirectory = this.parentDir %}
                            {% endif %}

                            {% if this.parentDir == null and (parentDirectory.userCreated == app.user or (parentDirectory.isPublic and app.user.accessGroup == getHighestRole())) %}
                                <a href="{{ path('app_files_file_edit_permission', {
                                    parentDir: parentDirectory.name,
                                }) }}" class="hover:text-yellow-400 duration-300" title="Permet de modifier les permissions du dossier"><twig:ux:icon class="w-6 h-6" name="fa6-solid:shield" /></a>
                            {% endif %}
                            {% if is_granted('file_write', parentDirectory) %}
                                <a href="{{ path('app_files_rename-directory', {
                                    path: file.path
                                }) }}" class="hover:text-blue-700 duration-300" title="Permet de renommer le dossier"><twig:ux:icon class="w-6 h-6" name="fa6-solid:pencil" /></a>
                                <a title="Permet de déplacer le dossier" href="{{ path('app_files_move', {
                                    path: file.path
                                }) }}" class="hover:text-blue-700 duration-300"><twig:ux:icon class="w-6 h-6" name="mdi:folder-move" /></a>
                                <a href="{{ path('app_files_delete_directory', {
                                    path: file.path
                                }) }}" class="hover:text-red-700 duration-300" title="Permet de supprimer le dossier" onclick="event.preventDefault(); const url = this.href; customConfirm('Veux-tu vraiment supprimer ce dossier ?', 'Supprimer le dossier').then(confirmed => {
                                    if (confirmed) {
                                        window.location.href = url
                                    }
                                })"><twig:ux:icon class="w-6 h-6" name="fa6-solid:trash-can" /></a>
                            {% endif %}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# Mobile Card View #}
    <div class="lg:hidden mt-4">
        {# Mobile Sort Controls #}
        <div class="mb-4 flex items-center gap-2 bg-gray-50 dark:bg-gray-700 p-3 rounded-lg">
            <label for="mobile-sort" class="text-sm font-medium text-gray-700 dark:text-gray-300">Trier par:</label>
            <select id="mobile-sort"
                data-model="sortBy"
                data-action="live#update"
                class="flex-1 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 p-2">
                <option value="name" {{ sortBy == 'name' ? 'selected' : '' }}>Nom</option>
                <option value="size" {{ sortBy == 'size' ? 'selected' : '' }}>Taille</option>
                <option value="date" {{ sortBy == 'date' ? 'selected' : '' }}>Date</option>
                <option value="type" {{ sortBy == 'type' ? 'selected' : '' }}>Type</option>
            </select>
            <button
                type="button"
                data-model="sortDirection"
                data-value="{{ sortDirection == 'asc' ? 'desc' : 'asc' }}"
                data-action="live#update"
                class="p-2 text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-200 transition-colors"
                title="{{ sortDirection == 'asc' ? 'Tri croissant' : 'Tri décroissant' }}">
                <twig:ux:icon name="fa6-solid:chevron-{{ sortDirection == 'asc' ? 'up' : 'down' }}" class="w-4 h-4" />
            </button>
        </div>

        <div class="space-y-3">
        {% for file in this.files %}
            {% if this.parentDir == null %}
                {% set parentDirectory = get_parent_dir(file.path) %}
            {% else %}
                {% set parentDirectory = this.parentDir %}
            {% endif %}
            
            <div class="{{ parentDirectory.public ? 'bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700' : 'bg-gray-50 dark:bg-gray-900 border-gray-300 dark:border-gray-600' }} border rounded-lg p-4">
                {# File Header #}
                <div class="flex items-center gap-3 mb-3">
                    {% if file.type == 'file' %}
                        {% if not parentDirectory.public %}
                            <twig:ux:icon name="fa6-solid:lock" class="w-5 h-5 text-amber-600 dark:text-amber-500 flex-shrink-0 mr-1" />
                        {% endif %}
                        <twig:ux:icon name="{{ getIcons(file.path|basename) }}" class="w-8 h-8 flex-shrink-0" />
                        <div class="flex-1 min-w-0">
                            <h3 class="font-medium text-gray-900 dark:text-white truncate">{{ file.path|basename }}</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400">{{ file.size|show_size }} • {{ file.last_modified|time_diff }}</p>
                        </div>
                    {% else %}
                        {% if not parentDirectory.public %}
                            <twig:ux:icon name="fa6-solid:lock" class="w-5 h-5 text-amber-600 dark:text-amber-500 flex-shrink-0 mr-1" />
                        {% endif %}
                        <twig:ux:icon name="line-md:folder-filled" class="w-8 h-8 flex-shrink-0" />
                        <div class="flex-1 min-w-0">
                            <button
                                type="button"
                                data-model="path"
                                data-value="{{ file.path }}"
                                data-action="live#update"
                                class="font-medium text-gray-900 dark:text-white truncate text-left w-full">
                                {{ file.path|basename }}
                            </button>
                            <p class="text-sm text-gray-500 dark:text-gray-400">{{ file.size|show_size }} • {{ file.last_modified|time_diff }}</p>
                        </div>
                    {% endif %}
                </div>

                {# Access Groups #}
                <div class="mb-3">
                    <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Groupes d'accès:</p>
                    {% if parentDirectory.public %}
                        <div class="flex gap-1 flex-wrap">
                            {% for parentRole in getHigherRoles(parentDirectory.ownerRole) %}
                                <img class="w-6 h-6 rounded-full" title="{{ parentRole.name }}" src="{{ parentRole.image ?? ('https://ui-avatars.com/api/?name=' ~ parentRole.name) }}" alt="">
                            {% endfor %}
                            {% if parentDirectory.ownerRole is not null %}
                                <img class="w-6 h-6 rounded-full" title="{{ parentDirectory.ownerRole.name }}" src="{{ parentDirectory.ownerRole.image ?? ('https://ui-avatars.com/api/?name=' ~ parentDirectory.ownerRole.name) }}" alt="">
                            {% endif %}
                            {% for permission in parentDirectory.parentDirectoryPermissions %}
                                <img class="w-6 h-6 rounded-full" title="{{ permission.role.name }}" src="{{ parentDirectory.ownerRole.image ?? ('https://ui-avatars.com/api/?name=' ~ permission.role.name) }}" alt="">
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="flex items-center gap-1">
                            <span class="text-sm text-gray-600 dark:text-gray-300">Dossier privé</span>
                        </div>
                    {% endif %}
                </div>

                {# Actions #}
                <div class="flex gap-2 justify-end flex-wrap">
                    {% if file.type == 'file' %}
                        <button title="Voir" onclick="openPreviewModal('{{ file.path|basename }}', '{{ file.previewUrl }}', '{{ file.url }}')" class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20">
                            <twig:ux:icon class="w-5 h-5" name="fa6-solid:eye" />
                        </button>
                        <button title="Copier lien" onclick="navigator.clipboard.writeText('{{ file.previewUrl }}'); customAlert('Lien copié avec succès !', 'Copie réussie')" class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20">
                            <twig:ux:icon class="w-5 h-5" name="fa6-solid:clipboard" />
                        </button>
                        <a title="Télécharger" href="{{ file.url }}" class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20">
                            <twig:ux:icon class="w-5 h-5" name="fa6-solid:download" />
                        </a>
                        {% if is_granted('file_write', parentDirectory) %}
                            <a title="Renommer" href="{{ path('app_files_rename', { path: file.path }) }}" class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20">
                                <twig:ux:icon class="w-5 h-5" name="fa6-solid:pencil" />
                            </a>
                            <a title="Déplacer" href="{{ path('app_files_move', { path: file.path }) }}" class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20">
                                <twig:ux:icon class="w-5 h-5" name="mdi:file-move" />
                            </a>
                            <a title="Supprimer" onclick="event.preventDefault(); const url = this.href; customConfirm('Êtes-vous sûr de vouloir supprimer ce fichier ?', 'Supprimer le fichier').then(confirmed => { if (confirmed) { window.location.href = url } })" href="{{ path('app_files_delete', { filename: file.path }) }}" class="p-2 text-gray-600 hover:text-red-700 hover:bg-red-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-red-500 dark:hover:bg-red-900/20">
                                <twig:ux:icon class="w-5 h-5" name="fa6-solid:trash-can" />
                            </a>
                        {% endif %}
                    {% else %}
                        {% if this.parentDir == null and (parentDirectory.userCreated == app.user or (parentDirectory.isPublic and app.user.accessGroup == getHighestRole())) %}
                            <a href="{{ path('app_files_file_edit_permission', { parentDir: parentDirectory.name }) }}" class="p-2 text-gray-600 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-yellow-500 dark:hover:bg-yellow-900/20" title="Permissions">
                                <twig:ux:icon class="w-5 h-5" name="fa6-solid:shield" />
                            </a>
                        {% endif %}
                        {% if is_granted('file_write', parentDirectory) %}
                            <a href="{{ path('app_files_rename-directory', { path: file.path }) }}" class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20" title="Renommer">
                                <twig:ux:icon class="w-5 h-5" name="fa6-solid:pencil" />
                            </a>
                            <a title="Déplacer" href="{{ path('app_files_move', { path: file.path }) }}" class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20">
                                <twig:ux:icon class="w-5 h-5" name="mdi:folder-move" />
                            </a>
                            <a href="{{ path('app_files_delete_directory', { path: file.path }) }}" class="p-2 text-gray-600 hover:text-red-700 hover:bg-red-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-red-500 dark:hover:bg-red-900/20" title="Supprimer" onclick="event.preventDefault(); const url = this.href; customConfirm('Êtes-vous sûr de vouloir supprimer ce dossier ?', 'Supprimer le dossier').then(confirmed => { if (confirmed) { window.location.href = url } })">
                                <twig:ux:icon class="w-5 h-5" name="fa6-solid:trash-can" />
                            </a>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
        </div>
    </div>
</div>
