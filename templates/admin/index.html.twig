{% extends 'base.html.twig' %}

{% block title %}Administration - Tableau de bord{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 md:px-8 lg:px-16 mb-4">
        <div class="mt-4">
            <h1 class="text-2xl md:text-3xl font-bold mb-6 text-gray-900 dark:text-white">Tableau de bord administrateur</h1>

            <!-- Statistiques générales -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm p-6">
                    <div class="flex items-center">
                        <div class="p-3 bg-blue-100 dark:bg-blue-900/20 rounded-full">
                            <twig:ux:icon name="fa6-solid:users" class="w-6 h-6 text-blue-600 dark:text-blue-400" />
                        </div>
                        <div class="ml-4">
                            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total utilisateurs</p>
                            <p class="text-2xl font-bold text-gray-900 dark:text-white">{{ total_users }}</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm p-6">
                    <div class="flex items-center">
                        <div class="p-3 bg-green-100 dark:bg-green-900/20 rounded-full">
                            <twig:ux:icon name="fa6-solid:chart-line" class="w-6 h-6 text-green-600 dark:text-green-400" />
                        </div>
                        <div class="ml-4">
                            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Total actions</p>
                            <p class="text-2xl font-bold text-gray-900 dark:text-white">{{ total_actions }}</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm p-6">
                    <div class="flex items-center">
                        <div class="p-3 bg-purple-100 dark:bg-purple-900/20 rounded-full">
                            <twig:ux:icon name="fa6-solid:clock" class="w-6 h-6 text-purple-600 dark:text-purple-400" />
                        </div>
                        <div class="ml-4">
                            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Moyenne par jour</p>
                            <p class="text-2xl font-bold text-gray-900 dark:text-white">{{ (total_actions / 30)|round }}</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Graphiques -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                <!-- Graphique en camembert des types d'actions -->
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                    <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Répartition des actions par type</h2>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Distribution des différents types d'actions effectuées</p>
                    </div>
                    <div class="p-4 md:p-6">
                        <div style="height: 350px; position: relative;">
                            {{ render_chart(action_types_chart) }}
                        </div>
                    </div>
                </div>

                <!-- Graphique d'activité quotidienne -->
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                    <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Activité des 30 derniers jours</h2>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Évolution du nombre d'actions par jour</p>
                    </div>
                    <div class="p-4 md:p-6">
                        <div style="height: 300px;">
                            {{ render_chart(daily_activity_chart, {'responsive': true, 'maintainAspectRatio': false}) }}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Graphique des utilisateurs les plus actifs -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                    <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Utilisateurs les plus actifs</h2>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Top 5 des utilisateurs par nombre d'actions</p>
                    </div>
                    <div class="p-4 md:p-6">
                        <div style="height: 300px;">
                            {{ render_chart(active_users_chart, {'responsive': true, 'maintainAspectRatio': false}) }}
                        </div>
                    </div>
                </div>

                <!-- Actions récentes -->
                <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                    <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                        <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Actions récentes</h2>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Dernières actions effectuées par les utilisateurs</p>
                    </div>
                    <div class="p-4 md:p-6">
                        {% if recent_actions is empty %}
                            <div class="text-center py-8">
                                <div class="w-16 h-16 mx-auto mb-4 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center">
                                    <twig:ux:icon name="fa6-solid:clock" class="w-8 h-8 text-gray-400" />
                                </div>
                                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">Aucune action récente</h3>
                                <p class="text-gray-600 dark:text-gray-400">Les actions des utilisateurs apparaîtront ici.</p>
                            </div>
                        {% else %}
                            <div class="space-y-3 max-h-72 overflow-y-auto">
                                {% for action in recent_actions %}
                                    <div class="flex items-start gap-3 p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
                                        <div class="flex items-center justify-center w-8 h-8 rounded-full bg-white dark:bg-gray-800 shadow-sm flex-shrink-0">
                                            <twig:ux:icon name="{{ action.actionIcon }}" class="w-4 h-4 {{ action.actionColor }}" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-gray-900 dark:text-white">
                                                {{ action.description }}
                                            </p>
                                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                                                <span class="font-medium">{{ action.user.fullname }}</span> •
                                                <twig:ux:icon name="fa6-solid:clock" class="w-3 h-3 inline mr-1" />
                                                {{ action.createdAt|time_diff }}
                                            </p>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Actions rapides -->
            <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
                <div class="p-4 md:p-6 border-b border-gray-200 dark:border-gray-700">
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Actions rapides</h2>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Accès rapide aux fonctions d'administration</p>
                </div>
                <div class="p-4 md:p-6">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                        <a href="{{ path('app_admin_user_index') }}"
                           class="flex items-center gap-3 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors group">
                            <div class="p-2 bg-blue-100 dark:bg-blue-900/20 rounded-lg group-hover:bg-blue-200 dark:group-hover:bg-blue-900/40 transition-colors">
                                <twig:ux:icon name="fa6-solid:users" class="w-5 h-5 text-blue-600 dark:text-blue-400" />
                            </div>
                            <div>
                                <h3 class="font-medium text-gray-900 dark:text-white">Gérer les utilisateurs</h3>
                                <p class="text-sm text-gray-600 dark:text-gray-400">Ajouter, modifier ou supprimer</p>
                            </div>
                        </a>

                        <a href="{{ path('app_admin_access_group_index') }}"
                           class="flex items-center gap-3 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors group">
                            <div class="p-2 bg-green-100 dark:bg-green-900/20 rounded-lg group-hover:bg-green-200 dark:group-hover:bg-green-900/40 transition-colors">
                                <twig:ux:icon name="fa6-solid:user-group" class="w-5 h-5 text-green-600 dark:text-green-400" />
                            </div>
                            <div>
                                <h3 class="font-medium text-gray-900 dark:text-white">Groupes d'accès</h3>
                                <p class="text-sm text-gray-600 dark:text-gray-400">Gérer les permissions</p>
                            </div>
                        </a>

                        <a href="{{ path('app_admin_user_create') }}"
                           class="flex items-center gap-3 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors group">
                            <div class="p-2 bg-purple-100 dark:bg-purple-900/20 rounded-lg group-hover:bg-purple-200 dark:group-hover:bg-purple-900/40 transition-colors">
                                <twig:ux:icon name="fa6-solid:user-plus" class="w-5 h-5 text-purple-600 dark:text-purple-400" />
                            </div>
                            <div>
                                <h3 class="font-medium text-gray-900 dark:text-white">Nouvel utilisateur</h3>
                                <p class="text-sm text-gray-600 dark:text-gray-400">Créer un compte</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}