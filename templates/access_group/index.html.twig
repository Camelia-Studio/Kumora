{% extends 'base.html.twig' %}

{% block title %}Liste des groupes d'accès{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 md:px-8 lg:px-16 mt-4">
        <div class="p-4 md:p-6 bg-white border border-gray-200 rounded-lg shadow-xs dark:bg-gray-800 dark:border-gray-700">
            <h5 class="mb-4 text-xl md:text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Liste des groupes d'accès</h5>

            <div class="flex flex-col lg:flex-row lg:justify-end gap-2 mb-4">
                <a href="{{ path('app_access_group_new') }}" class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 rounded-lg dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800 transition-colors w-full lg:w-auto">
                    <twig:ux:icon name="fa6-solid:users" class="w-4 h-4 mr-2" />
                    Créer un groupe d'accès
                </a>
            </div>
            
            <div class="mb-4">
                {{ include('partials/alerts.html.twig') }}
            </div>

            {# Desktop Table View #}
            <div class="hidden lg:block relative overflow-x-auto shadow-md sm:rounded-lg">
                <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                    <tr>
                        <th scope="col" class="px-6 py-3">#</th>
                        <th scope="col" class="px-6 py-3">Nom</th>
                        <th scope="col" class="px-6 py-3">Position</th>
                        <th scope="col" class="px-6 py-3">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for access_group in access_groups %}
                        <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 border-gray-200">
                            <th scope="row" class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap dark:text-white">
                                {{ access_group.id }}
                            </th>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    {% if access_group.image %}
                                        <img src="{{ access_group.image }}" alt="{{ access_group.name }}" class="w-6 h-6 rounded-full object-cover flex-shrink-0">
                                    {% else %}
                                        <div class="w-6 h-6 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center flex-shrink-0">
                                            <twig:ux:icon name="fa6-solid:users" class="w-3 h-3 text-green-600 dark:text-green-400" />
                                        </div>
                                    {% endif %}
                                    {{ access_group.name }}
                                </div>
                            </td>
                            <td class="px-6 py-4">{{ access_group.position }}</td>
                            <td class="px-6 py-4 flex gap-2 light:text-black">
                                <a title="Modifier le groupe d'accès" href="{{ path('app_access_group_edit', { id: access_group.id }) }}" class="hover:text-blue-700 duration-300">
                                    <twig:ux:icon class="w-6 h-6" name="fa6-solid:pencil" />
                                </a>
                                <a title="Supprimer le groupe d'accès" href="{{ path('app_access_group_delete', { id: access_group.id }) }}" class="hover:text-red-700 duration-300">
                                    <twig:ux:icon class="w-6 h-6" name="fa6-solid:trash-can" />
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 border-gray-200">
                            <td colspan="4" class="px-6 py-4 text-center font-medium text-gray-500 dark:text-gray-400">
                                Aucun groupe d'accès trouvé !
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Mobile Card View #}
            <div class="lg:hidden space-y-3">
                {% for access_group in access_groups %}
                    <div class="bg-white border border-gray-200 rounded-lg p-4 dark:bg-gray-800 dark:border-gray-700">
                        {# Group Header #}
                        <div class="flex items-center gap-3 mb-3">
                            {% if access_group.image %}
                                <img src="{{ access_group.image }}" alt="{{ access_group.name }}" class="w-10 h-10 rounded-full flex-shrink-0 object-cover">
                            {% else %}
                                <div class="w-10 h-10 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center flex-shrink-0">
                                    <twig:ux:icon name="fa6-solid:users" class="w-5 h-5 text-green-600 dark:text-green-400" />
                                </div>
                            {% endif %}
                            <div class="flex-1 min-w-0">
                                <h3 class="font-medium text-gray-900 dark:text-white truncate">{{ access_group.name }}</h3>
                                <p class="text-sm text-gray-500 dark:text-gray-400">ID: {{ access_group.id }}</p>
                            </div>
                        </div>

                        {# Group Details #}
                        <div class="mb-4">
                            <div class="flex justify-between">
                                <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Position:</span>
                                <span class="text-sm text-gray-900 dark:text-white">{{ access_group.position }}</span>
                            </div>
                        </div>

                        {# Actions #}
                        <div class="flex gap-2 justify-end">
                            <a href="{{ path('app_access_group_edit', { id: access_group.id }) }}" 
                               class="p-2 text-gray-600 hover:text-blue-700 hover:bg-blue-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-blue-500 dark:hover:bg-blue-900/20"
                               title="Modifier le groupe d'accès">
                                <twig:ux:icon class="w-5 h-5" name="fa6-solid:pencil" />
                            </a>
                            <a href="{{ path('app_access_group_delete', { id: access_group.id }) }}" 
                               class="p-2 text-gray-600 hover:text-red-700 hover:bg-red-50 rounded-lg duration-300 dark:text-gray-400 dark:hover:text-red-500 dark:hover:bg-red-900/20"
                               title="Supprimer le groupe d'accès">
                                <twig:ux:icon class="w-5 h-5" name="fa6-solid:trash-can" />
                            </a>
                        </div>
                    </div>
                {% else %}
                    <div class="bg-white border border-gray-200 rounded-lg p-6 text-center dark:bg-gray-800 dark:border-gray-700">
                        <div class="w-16 h-16 bg-gray-100 dark:bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                            <twig:ux:icon name="fa6-solid:users" class="w-8 h-8 text-gray-400 dark:text-gray-500" />
                        </div>
                        <p class="text-gray-500 dark:text-gray-400 mb-4">Aucun groupe d'accès trouvé !</p>
                        <a href="{{ path('app_access_group_new') }}" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors">
                            <twig:ux:icon name="fa6-solid:plus" class="w-4 h-4" />
                            Créer le premier groupe
                        </a>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
