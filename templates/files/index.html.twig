{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 md:px-8 lg:px-16"
         data-controller="drag-drop-upload"
         data-drag-drop-upload-base-url-value="{{ path('app_files_upload_ajax', {path: '__PATH__'}) }}">

        {# Overlay de drag & drop #}
        <div data-drag-drop-upload-target="overlay"
             class="hidden fixed inset-0 bg-blue-600/20 dark:bg-blue-600/30 backdrop-blur-sm z-40 flex items-center justify-center pointer-events-none">
            <div class="bg-white dark:bg-gray-800 rounded-lg p-8 shadow-2xl border-4 border-dashed border-blue-600 dark:border-blue-400">
                <div class="flex flex-col items-center gap-4">
                    <svg class="w-16 h-16 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"></path>
                    </svg>
                    <div class="text-center">
                        <p class="text-xl font-bold text-gray-900 dark:text-white">Déposez vos fichiers ici</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Relâchez pour uploader</p>
                    </div>
                </div>
            </div>
        </div>

        <div data-drag-drop-upload-target="dropzone">
            <h1 class="text-center text-xl md:text-2xl font-bold mt-4">Liste des fichiers</h1>
            <div class="mt-4">
                {{ include('partials/alerts.html.twig') }}
            </div>

            <twig:FileTable />
        </div>

        {# Modal de prévisualisation des fichiers #}
        {{ include('components/FilePreviewModal.html.twig') }}
    </div>
{% endblock %}
