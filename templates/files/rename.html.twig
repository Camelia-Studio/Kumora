{% extends 'base.html.twig' %}

{% block body %}
    <div class="container mx-auto px-16 mt-4">
        <div class="block p-6 bg-white border border-gray-200 rounded-lg shadow-xs dark:bg-gray-800 dark:border-gray-700">
            <h3 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Renommer le {{ type }} {{ filepath }}</h3>
            {{ form_start(form) }}
            {{ form_row(form.newName) }}
            <div class="flex gap-2">
                {{ form_widget(form.submit) }}
                <a href="{{ path('app_files_index', {
                    path: path,
                }) }}" class="py-2.5 px-5 me-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700">Retour à la liste</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block title %}
    Renommer un {{ type }}
{% endblock %}

