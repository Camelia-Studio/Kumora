{% extends 'base.html.twig' %}

{% block body %}
    <div class="container mx-auto px-16 mt-4">
        <div class="block p-6 bg-white border border-gray-200 rounded-lg shadow-xs dark:bg-gray-800 dark:border-gray-700">
            <h3 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Déplacement en masse</h3>

            <div class="mb-4">
                <p class="text-gray-700 dark:text-gray-300 mb-2">{{ files|length }} élément(s) sélectionné(s) :</p>
                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-3 max-h-48 overflow-y-auto">
                    <ul class="space-y-1">
                        {% for file in files %}
                            <li class="flex items-start gap-2">
                                <twig:ux:icon name="fa6-solid:file" class="w-4 h-4 mt-0.5 text-gray-500 dark:text-gray-400 flex-shrink-0" />
                                <span class="font-mono text-sm text-gray-700 dark:text-gray-300 break-all">/{{ file }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            {{ form_start(form) }}
            {{ form_row(form.path) }}
            <div class="flex gap-2">
                {{ form_widget(form.submit) }}
                <a href="{{ path('app_files_index', {
                    path: sourcePath,
                }) }}" class="py-2.5 px-5 me-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-100 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block title %}
    Déplacement en masse
{% endblock %}
