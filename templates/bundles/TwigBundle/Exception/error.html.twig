{% extends 'base.html.twig' %}
{% block body %}
    <div class="container mx-auto px-16 flex items-center justify-center flex-col">

        <h1 class="text-5xl font-black text-center">{{ status_code }} -
            {% if status_code == 400 %}
                Requête invalide.
            {% elseif status_code == 401 %}
                Non autorisé
            {% elseif status_code == 403 %}
                Accès interdit.
            {% elseif status_code == 404 %}
                Cette page n'existe pas.
            {% elseif status_code == 413 %}
                Fichier trop volumineux.
            {% elseif status_code == 422 %}
                Données invalides.
            {% elseif status_code == 500 %}
                Erreur interne du serveur.
            {% elseif status_code == 503 %}
                Service indisponible.
            {% elseif status_code == 507 %}
                Stockage insuffisant.
            {% elseif status_code == 522 %}
                Chargement trop long.
            {% else %}
                Une erreur est survenue.
            {% endif %}</h1>
        <img class="w-96 mt-16" src="{{ asset('images/logo.png') }}" alt="Mascotte Camélia Studio">

        <p class="text-2xl mt-8 font-semibold">
            Il semblerait que tu te soit perdu. Laisse moi te raccompagner sur le droit chemin.
        </p>

        <a href="{{ path('app_home') }}"
           class=" mt-8 text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 me-2 mb-2 dark:bg-blue-600 dark:hover:bg-blue-700 focus:outline-none dark:focus:ring-blue-800">Retourner
            à l'accueil</a>
    </div>
{% endblock %}